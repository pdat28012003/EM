{

  "AppSettings": {

    "Token": "#{JWT_TOKEN}#"

  },

  "EmailSettings": {

    "Email": "#{EMAIL_USER}#",

    "Password": "#{EMAIL_PASSWORD}#",

    "Host": "#{EMAIL_HOST}#",

    "Port": 587

  },

  "ConnectionStrings": {

    "DefaultConnection": "#{CONNECTION_STRING}#"

  },

  "Logging": {

    "LogLevel": {

      "Default": "Information",

      "Microsoft.AspNetCore": "Warning"

    }

  },

  "AllowedHosts": "*"

}

